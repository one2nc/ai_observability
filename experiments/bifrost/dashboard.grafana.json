{
  "dashboard": {
    "description": "Bifrost gateway metrics + OpenLLMetry auto + manual RAG + FastAPI HTTP.",
    "panels": [
      {
        "collapsed": false,
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 0
        },
        "title": "Bifrost \u2014 AI Gateway Metrics",
        "type": "row"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "Request rate by provider, model, and operation type.",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 1
        },
        "targets": [
          {
            "expr": "sum(rate(bifrost_upstream_requests_total[1m])) by (provider, method, model)",
            "legendFormat": "{{method}} {{provider}}/{{model}}"
          }
        ],
        "title": "Bifrost Upstream Requests",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "p50 provider latency by model and operation.",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 8,
          "y": 1
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(bifrost_upstream_latency_seconds_bucket[1m])) by (le, method, model))",
            "legendFormat": "p50 {{method}} {{model}}"
          }
        ],
        "title": "Bifrost Upstream Latency",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "Retry rate and count by operation. Non-zero = provider instability.",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 16,
          "y": 1
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(bifrost_request_retries_bucket[1m])) by (le, method))",
            "legendFormat": "p95 retries {{method}}"
          },
          {
            "expr": "sum(rate(bifrost_request_retries_count[1m])) by (method)",
            "legendFormat": "retry samples {{method}}"
          }
        ],
        "title": "Bifrost Retries",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "Token rate by provider, model, and direction (input/output).",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 9
        },
        "targets": [
          {
            "expr": "sum(rate(bifrost_input_tokens_total[1m])) by (provider, method, model)",
            "legendFormat": "input {{provider}} {{method}} {{model}}"
          }
        ],
        "title": "Bifrost Tokens",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "Cost rate (USD/s) by provider and model.",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 8,
          "y": 9
        },
        "targets": [
          {
            "expr": "sum(rate(bifrost_cost_USD_total[1m])) by (provider, method, model)",
            "legendFormat": "{{provider}} {{method}} {{model}}"
          }
        ],
        "title": "Bifrost Cost Rate",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "Percentage of requests that succeeded. Below 100% = provider errors.",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 16,
          "y": 9
        },
        "targets": [
          {
            "expr": "sum(bifrost_success_requests_total) / sum(bifrost_upstream_requests_total) * 100",
            "legendFormat": "success %"
          }
        ],
        "title": "Gateway Success %",
        "type": "stat"
      },
      {
        "collapsed": false,
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 17
        },
        "title": "OpenLLMetry \u2014 LLM Metrics (auto-instrumented)",
        "type": "row"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "Token rate by operation, model, and token type (input/output).",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 18
        },
        "targets": [
          {
            "expr": "sum(rate(gen_ai_client_token_usage_sum{service_name=\"ai-obs-bifrost\"}[1m])) by (gen_ai_operation_name, gen_ai_response_model, gen_ai_token_type)",
            "legendFormat": "{{gen_ai_operation_name}} {{gen_ai_response_model}} {{gen_ai_token_type}}"
          }
        ],
        "title": "OpenLLMetry Token Usage",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "p95 token count per call by model and token type.",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 8,
          "y": 18
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(gen_ai_client_token_usage_bucket{service_name=\"ai-obs-bifrost\"}[1m])) by (le, gen_ai_operation_name, gen_ai_response_model, gen_ai_token_type))",
            "legendFormat": "p95 {{gen_ai_operation_name}} {{gen_ai_response_model}} {{gen_ai_token_type}}"
          }
        ],
        "title": "OpenLLMetry Token Usage Distribution",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "p50 LLM call duration by operation and model.",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 16,
          "y": 18
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(gen_ai_client_operation_duration_seconds_bucket{service_name=\"ai-obs-bifrost\"}[1m])) by (le, gen_ai_operation_name, gen_ai_response_model))",
            "legendFormat": "p50 {{gen_ai_operation_name}} {{gen_ai_response_model}}"
          }
        ],
        "title": "OpenLLMetry Operation Duration",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "Completions rate by model/finish_reason + embedding vector elements.",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 26
        },
        "targets": [
          {
            "expr": "sum(rate(gen_ai_client_generation_choices_choice_total{service_name=\"ai-obs-bifrost\"}[1m])) by (gen_ai_response_model, gen_ai_response_finish_reason)",
            "legendFormat": "{{gen_ai_response_model}} {{gen_ai_response_finish_reason}}"
          },
          {
            "expr": "sum(rate(llm_openai_embeddings_vector_size_element_total{service_name=\"ai-obs-bifrost\"}[1m]))",
            "legendFormat": "embedding vector elements"
          }
        ],
        "title": "OpenLLMetry Choices And Embeddings",
        "type": "timeseries"
      },
      {
        "collapsed": false,
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 34
        },
        "title": "Manual \u2014 RAG Pipeline Metrics",
        "type": "row"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "Cosine similarity of retrieved chunks.",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 35
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(rag_retrieve_similarity_score_bucket{service_name=\"ai-obs-bifrost\"}[1m])) by (le))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(rag_retrieve_similarity_score_bucket{service_name=\"ai-obs-bifrost\"}[1m])) by (le))",
            "legendFormat": "p95"
          }
        ],
        "title": "Retrieval Similarity (p50/p95)",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "Retrieval operations per second.",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 35
        },
        "targets": [
          {
            "expr": "sum(rate(rag_retrieve_count_total{service_name=\"ai-obs-bifrost\"}[1m]))",
            "legendFormat": "retrievals/s"
          }
        ],
        "title": "Retrieval Count Rate",
        "type": "timeseries"
      },
      {
        "collapsed": false,
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 43
        },
        "title": "FastAPI \u2014 HTTP Metrics (auto-instrumented)",
        "type": "row"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "HTTP requests per second by endpoint.",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 44
        },
        "targets": [
          {
            "expr": "sum(rate(http_server_duration_milliseconds_count{service_name=\"ai-obs-bifrost\"}[1m])) by (http_target)",
            "legendFormat": "{{http_target}}"
          }
        ],
        "title": "Request Rate (req/s)",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "End-to-end latency per endpoint.",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 44
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_milliseconds_bucket{service_name=\"ai-obs-bifrost\"}[1m])) by (le, http_target))",
            "legendFormat": "p95 {{http_target}}"
          }
        ],
        "title": "Request Duration p95 (ms)",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "Concurrent in-flight requests.",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 52
        },
        "targets": [
          {
            "expr": "http_server_active_requests{service_name=\"ai-obs-bifrost\"}",
            "legendFormat": "{{http_method}} active"
          }
        ],
        "title": "Active Requests",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "Rate of 5xx responses.",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 52
        },
        "targets": [
          {
            "expr": "sum(rate(http_server_duration_milliseconds_count{service_name=\"ai-obs-bifrost\", http_status_code=~\"5..\"}[1m])) by (http_target)",
            "legendFormat": "5xx {{http_target}}"
          }
        ],
        "title": "Error Rate (5xx)",
        "type": "timeseries"
      }
    ],
