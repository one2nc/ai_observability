# Embeddings (Bifrost gateway on host)
EMBED_API_KEY=your-bifrost-virtual-key
EMBED_BASE_URL=http://host.docker.internal:8800/v1
EMBED_MODEL=openai/text-embedding-3-small
EMBED_DIM=1536

# Chat (Bifrost gateway on host)
CHAT_API_KEY=your-bifrost-virtual-key
CHAT_BASE_URL=http://host.docker.internal:8800/v1
CHAT_MODEL=openrouter/gpt-4o-mini

# Postgres (running via infra/)
DATABASE_URL=postgresql://rag:rag@host.docker.internal:5432/rag

# OpenTelemetry (shared gateway; sink selected in infra)
OTEL_SERVICE_NAME=ai-obs-bifrost
OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4418
