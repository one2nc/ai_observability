# Embeddings
EMBED_API_KEY=your-embed-api-key
EMBED_BASE_URL=https://openrouter.ai/api/v1
EMBED_MODEL=openai/text-embedding-3-small
EMBED_DIM=1536

# Chat (Bifrost gateway on host)
CHAT_API_KEY=your-chat-api-key
CHAT_BASE_URL=http://host.docker.internal:8000/v1
CHAT_MODEL=claude-sonnet-4

# Postgres (running via infra/)
DATABASE_URL=postgresql://rag:rag@host.docker.internal:5432/rag

# OpenTelemetry (SigNoz running via infra/)
OTEL_SERVICE_NAME=ai-obs-01-otel
OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4418
