# ─────────────────────────────────────────────────────────────────────────────
# Portkey Local POC — Environment Variables
# Copy to .env and fill in your real API keys.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Gateway auth ─────────────────────────────────────────────────────────────
# Validated by the self-hosted gateway — all SDK requests send this as
# the x-portkey-api-key header. Can be any string for local use.
PORTKEY_CLIENT_AUTH=local-test-key

# ── Gateway URL (local Docker) ───────────────────────────────────────────────
PORTKEY_GATEWAY_URL=http://localhost:8787/v1

# ── OpenAI API key ────────────────────────────────────────────────────────────
# Forwarded by the local gateway directly to api.openai.com.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ── Model configuration ───────────────────────────────────────────────────────
PRIMARY_PROVIDER=openai
PRIMARY_MODEL=gpt-4o-mini

# Fallback model (used in Demo 4 — fallback routing)
FALLBACK_MODEL=gpt-4o
