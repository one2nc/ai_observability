# OpenAI Agents SDK
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4.1-mini
OPENAI_AGENTS_API=responses
# Optional for an OpenAI-compatible endpoint:
# OPENAI_BASE_URL=https://api.openai.com/v1

# For Bifrost, use the virtual key and chat-completions mode:
# OPENAI_API_KEY=<bifrost-virtual-key>
# OPENAI_MODEL=openai/gpt-4o-mini
# OPENAI_AGENTS_API=chat_completions
# OPENAI_BASE_URL=http://host.docker.internal:8000/v1

# OpenTelemetry collector gateway
OTEL_SERVICE_NAME=ai-obs-openllmetry-openai-agents
OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4418
