# Copy to .enc and fill in secrets.
# Both "key: value" and "KEY=value" formats are accepted.

gateway: true
sink: grafana

bifrost_provider: openai
bifrost_api_key: replace-with-provider-token
bifrost_port: 8000

# Optional. Defaults to http://host.docker.internal:4418.
otel_exporter_otlp_endpoint: http://host.docker.internal:4418

# Optional overrides. Defaults are derived from otel_exporter_otlp_endpoint.
# otel_exporter_otlp_traces_endpoint: http://host.docker.internal:4418/v1/traces
# otel_exporter_otlp_metrics_endpoint: http://host.docker.internal:4418/v1/metrics
